            { id: 4, title: "2019 Subaru Forester Dynamic", price: "KES 3,850,000", image: "media/showroom_4.jpg", engine: "2.5L Boxer Engine", mileage: "52,000 km", grade: "4.0" },
            { id: 5, title: "2021 Toyota RAV4 G-Package", price: "KES 4,950,000", image: "media/showroom_5.jpg", engine: "2.5L Hybrid Matrix", mileage: "19,000 km", grade: "A" },
            { id: 6, title: "2018 Mercedes-Benz C200 AMG", price: "KES 4,800,000", image: "media/showroom_6.jpg", engine: "1.5L Turbo Drive", mileage: "46,000 km", grade: "4.5" },
            { id: 7, title: "2019 Mazda CX-5 SkyActiv", price: "KES 3,350,000", image: "media/showroom_7.jpg", engine: "2.2L Diesel Variant", mileage: "61,000 km", grade: "4.0" },
            { id: 8, title: "2018 Honda CR-V Masterpiece", price: "KES 3,900,000", image: "media/showroom_8.jpg", engine: "1.5L VTEC Turbo", mileage: "44,500 km", grade: "4.5" },
            { id: 9, title: "2020 Nissan X-Trail Rogue", price: "KES 3,150,000", image: "media/showroom_9.jpg", engine: "2.0L PureDrive", mileage: "55,000 km", grade: "4.0" }
        ];

        function scrollToSection(id) {
            const destination = document.getElementById(id);
            if(destination) destination.scrollIntoView({ behavior: 'smooth' });
        }

        // Generate the 10 showroom components into the view layer automatically
        function assembleShowroomElements() {
            const track = document.getElementById('showroomTrack');
            track.innerHTML = '';
            
            showroomInventoryArray.forEach(car => {
                const element = document.createElement('div');
                element.id = `showroom-card-node-${car.id}`;
                element.className = "bg-white border border-gray-200 car-card-transition snap-start flex-shrink-0 w-[285px] flex flex-col justify-between overflow-hidden rounded-sm shadow-sm";
                element.innerHTML = `
                    <div>
                        <div class="h-40 bg-neutral-200 relative overflow-hidden">
                            <img src="${car.image}" alt="JDM Stock Resource" class="w-full h-full object-cover" onerror="this.src='https://images.unsplash.com/photo-1549399542-7e3f8b79c341?auto=format&fit=crop&w=400&q=80'">
                        </div>
                        <div class="p-4 text-xs">
                            <h4 class="font-bold tracking-tight text-neutral-900 uppercase truncate">${car.title}</h4>
                            <p class="text-[#111111] font-black mt-1 text-[13px]">${car.price}</p>
                            
                            <div id="hidden-card-spec-panel-${car.id}" class="hidden mt-3 pt-3 border-t border-gray-100 grid grid-cols-2 gap-2 text-[10px]">
                                <div class="bg-[#F4F4F6] p-1.5 rounded-sm"><span class="text-[8px] text-gray-400 block uppercase font-mono">Engine</span><span class="font-bold text-gray-700">${car.engine}</span></div>
                                <div class="bg-[#F4F4F6] p-1.5 rounded-sm"><span class="text-[8px] text-gray-400 block uppercase font-mono">Mileage</span><span class="font-bold text-gray-700">${car.mileage}</span></div>
                                <div class="bg-[#F4F4F6] p-1.5 rounded-sm"><span class="text-[8px] text-gray-400 block uppercase font-mono">Auction Grade</span><span class="font-bold text-green-700">${car.grade}</span></div>
                                <div class="bg-[#F4F4F6] p-1.5 rounded-sm"><span class="text-[8px] text-gray-400 block uppercase font-mono">Status</span><span class="font-bold text-blue-700">Available</span></div>
                            </div>
                        </div>
                    </div>
                    <div class="p-4 pt-0">
                        <button id="trigger-btn-${car.id}" onclick="triggerCardSpecsDisplay(${car.id})" class="w-full bg-transparent border border-neutral-900 hover:bg-neutral-900 hover:text-white text-neutral-900 text-[10px] font-bold uppercase tracking-wider py-2 text-center rounded-sm transition">View Details</button>
                    </div>
                `;
                track.appendChild(element);
            });
        }

        // Toggle card spec visibility layout script module
        function triggerCardSpecsDisplay(id) {
            const card = document.getElementById(`showroom-card-node-${id}`);
            const block = document.getElementById(`hidden-card-spec-panel-${id}`);
            const button = document.getElementById(`trigger-btn-${id}`);
            
            if(block.classList.contains('hidden')) {
                card.classList.remove('w-[285px]');
                card.classList.add('w-[320px]', 'border-[#D4AF37]', 'shadow-md');
                block.classList.remove('hidden');
                button.innerText = "Close Details";
                button.className = "w-full bg-neutral-800 text-white text-[10px] font-bold uppercase tracking-wider py-2 text-center rounded-sm transition";
            } else {
                card.classList.remove('w-[320px]', 'border-[#D4AF37]', 'shadow-md');
                card.classList.add('w-[285px]');
                block.classList.add('hidden');
                button.innerText = "View Details";
                button.className = "w-full bg-transparent border border-neutral-900 hover:bg-neutral-900 hover:text-white text-neutral-900 text-[10px] font-bold uppercase tracking-wider py-2 text-center rounded-sm transition";
            }
        }

        // Inbound dual configuration submit pipeline handler
        async function handleInquiryTransmission(event) {
            event.preventDefault();
            const bundleData = {
                name: document.getElementById('clientName').value,
                email: document.getElementById('clientEmail').value,
                phone: document.getElementById('clientPhone').value,
                type: document.getElementById('clientType').value,
                vehicle: document.getElementById('clientVehicle').value,
                notes: document.getElementById('clientNotes').value
            };

            try {
                const triggerEndpoint = await fetch('http://localhost:5000/api/inquiry', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bundleData)
                });
                if(triggerEndpoint.ok) {
                    alert('Log transmission confirmed! Your vehicle specifications are now routing to both processing systems successfully.');
                    document.getElementById('jdmInquiryEngine').reset();
                } else {
                    alert('Data communication error on local node.');
                }
            } 
