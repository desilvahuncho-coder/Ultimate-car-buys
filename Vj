    <script>
        // Array mapping structural details for exactly 10 showroom objects matching your setup layout parameters
        const showroomInventoryArray = [
            { id: 0, title: "2021 Toyota Land Cruiser ZX", price: "KES 12,800,000", image: "media/showroom_0.jpg", engine: "3.5L V6 Twin-Turbo", mileage: "24,000 km", grade: "5.0" },
